# Sauron Edge — Environment Variables
# ─────────────────────────────────────
# Copy to .env in the working directory (or the directory you launch the
# component from) and edit as needed.
#
# Greengrass automatically injects most of these at runtime — you only need
# to set them manually for local development/testing outside of Greengrass.

# ─────────────────────────────────────
# Configuration file path
# ─────────────────────────────────────
# Override the default config file location.
# Default: ~/.config/sauron/config.yaml
# CONFIGURATION_FILE_PATH=~/.config/sauron/config.yaml

# ─────────────────────────────────────
# Greengrass / IoT Core identity
# ─────────────────────────────────────
# AWS Greengrass v2 sets this automatically when launching a component.
# It determines the MQTT topic: devices/{AWS_IOT_THING_NAME}/telemetry
# Set it here only for local testing outside of Greengrass.
# AWS_IOT_THING_NAME=my-device-001

# ─────────────────────────────────────
# Greengrass IPC (set automatically by nucleus — DO NOT override)
# ─────────────────────────────────────
# AWS_GG_NUCLEUS_DOMAIN_SOCKET_FILEPATH_FOR_COMPONENT=/tmp/greengrass/ipc.sock
# SVCUID=<auth-token-injected-by-nucleus>
