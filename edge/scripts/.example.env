# Sauron Edge — Deployment Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to scripts/.env.deploy and fill in real values.
# This file is read only by scripts/deploy.py on your DEVELOPER machine.
# Do NOT deploy this file to the Pi or commit it to source control.
#
# Usage:
#   uv run --extra deploy python scripts/deploy.py --version 1.0.0 --dry-run


# ─────────────────────────────────────
# AWS credentials / identity
# ─────────────────────────────────────

# Named profile from ~/.aws/credentials (recommended).
# Leave blank to use environment variables (AWS_ACCESS_KEY_ID, etc.)
# or the instance profile if running on EC2.
AWS_PROFILE=

# AWS region where your IoT Core and Greengrass resources live.
AWS_REGION=us-east-1


# ─────────────────────────────────────
# S3 artifact storage
# ─────────────────────────────────────

# Bucket name ONLY — no s3:// prefix, no trailing slash.
# Artifacts land at:
#   s3://<bucket>/artifacts/sauron-edge/<version>/sauron-edge-<version>.zip
S3_ARTIFACT_BUCKET=my-sauron-artifacts


# ─────────────────────────────────────
# Greengrass component
# ─────────────────────────────────────

# Fully-qualified component name.  Must match what you registered in Greengrass.
GG_COMPONENT_NAME=com.sauron.edge

# Minimum Greengrass nucleus version required on the device.
GG_NUCLEUS_VERSION_REQ=>=2.9.0


# ─────────────────────────────────────
# Greengrass deployment target
# ─────────────────────────────────────

# The ARN of the thing group or core device to deploy to.
# Find it in the AWS Console → IoT Core → Manage → Thing Groups → <your group> → ARN
# or: aws iot describe-thing-group --thing-group-name <name> --query thingGroupArn
GG_TARGET_ARN=arn:aws:iot:us-east-1:123456789012:thinggroup/sauron-devices

# Human-readable name shown in the Greengrass Deployments console.
GG_DEPLOYMENT_NAME=sauron-edge-production


# ─────────────────────────────────────
# Optional component settings
# ─────────────────────────────────────

# Dashboard port baked into the component recipe.
DASHBOARD_PORT=5000
